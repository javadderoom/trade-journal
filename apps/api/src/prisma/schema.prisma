// Prisma Schema for معامله‌یار (Mo'amele-yar) Trading Journal Platform

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["fullTextSearchPostgres"]
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  phone            String?          @unique
  password_hash    String
  name             String?
  plan             Plan             @default(FREE)
  role             Role             @default(USER)
  created_at       DateTime         @default(now())
  display_currency DisplayCurrency  @default(USD)
  avatar_url       String?
  deleted_at       DateTime?
  accounts         Account[]
  journalEntries   JournalEntry[]
  subscriptions    Subscription[]
  trades           Trade[]
  importJobs       ImportJob[]
  tags             Tag[]
  emotions         Emotion[]
  refresh_tokens   RefreshToken[]
  userDiscounts    UserDiscount[]
  manualReceipts   ManualReceipt[]
   mistakeIncidents MistakeIncident[]
   cryptoTransactions CryptoTransaction[]
   checkoutSessions CheckoutSession[]
   conversations Conversation[]             @relation("UserConversations")
   assignedConversations Conversation[]     @relation("AdminConversations")
   sentMessages Message[]                   @relation("MessageSender")
   activities ConversationActivity[]        @relation("ActivityActor")
}

model Account {
  id                 String              @id @default(uuid())
  user_id            String
  user               User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  broker_name        String?
  account_number     String?
  currency           String              @default("USD")
  created_at         DateTime            @default(now())
  trades             Trade[]
  importJobs         ImportJob[]
  account_tokens     AccountToken[]
  last_sync_at       DateTime?
  exchangeConnection ExchangeConnection?
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
  user_agent String?
  last_used_at DateTime @default(now())

  @@index([user_id])
}

model AccountToken {
  id         String   @id @default(uuid())
  account_id String
  account    Account  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  token      String   @unique
  name       String?
  created_at DateTime @default(now())

  @@index([account_id])
}

model Trade {
  id            String       @id @default(uuid())
  account_id    String
  user_id       String
  account       Account      @relation(fields: [account_id], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  symbol        String
  direction     Direction
  open_time     DateTime
  close_time    DateTime?
  open_price    Float
  close_price   Float?       // Aggregated: last exit price (null if still open)
  lot_size      Float        // Aggregated: original entry lot size
  stop_loss     Float?
  take_profit   Float?
  profit_usd    Float        // Aggregated: sum of all exit P&L
  commission    Float        // Aggregated: sum of all execution commissions
  swap          Float        // Aggregated: sum of all execution swaps
  pips          Float        // Aggregated: pips from last exit
  r_multiple    Float        // Aggregated: R-multiple from last exit
  tags          String[]
  emotion       String?
  notes         String?
  ticket        Int?         // MT4/MT5 deal ticket for deduplication
  import_source ImportSource @default(MANUAL)
  screenshots   String[]     @default([])
  chart_data         Json?
  analysis_timeframe String?
  entry_timeframe    String?
  created_at         DateTime     @default(now())

  executions    Execution[]

  @@unique([account_id, ticket])
  @@index([user_id])
  @@index([account_id])
  @@index([open_time])
  @@index([user_id, open_time])
  mistakeIncidents MistakeIncident[]
}

model Execution {
  id          String        @id @default(uuid())
  trade_id    String
  trade       Trade         @relation(fields: [trade_id], references: [id], onDelete: Cascade)
  type        ExecutionType
  lot_size    Float
  price       Float
  profit_usd  Float         @default(0)  // Realized P&L for this execution (exits only)
  commission  Float         @default(0)
  swap        Float         @default(0)
  pips        Float         @default(0)
  r_multiple  Float         @default(0)
  close_time  DateTime?     // When this exit was closed
  executed_at DateTime      @default(now())
  notes       String?

  @@index([trade_id])
  @@index([executed_at])
}

enum ExecutionType {
  ENTRY
  EXIT
}

model MistakeIncident {
  id         String   @id @default(uuid())
  user_id    String
  trade_id   String
  rule_key   String   // "NO_SL" | "SL_NOT_RESPECTED" | "REVENGE_TRADE" | "UNUSUAL_SIZE" | "WEAK_STRATEGY" | "WEAK_HOUR"
  label      String   // user-visible Persian label
  cost_usd   Float    // abs(profit_usd) of this trade
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [trade_id], references: [id], onDelete: Cascade)

  @@unique([trade_id, rule_key])
  @@index([user_id])
}

model JournalEntry {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  date       DateTime
  body       String
  mood       Mood?
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([user_id, date])
}

model ImportJob {
  id             String       @id @default(uuid())
  user_id        String
  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account_id     String?
  account        Account?     @relation(fields: [account_id], references: [id], onDelete: SetNull)
  filename       String
  status         ImportStatus @default(UPLOADED)
  rows_total     Int
  rows_imported  Int          @default(0)
  errors         String[]
  created_at     DateTime     @default(now())

  @@index([user_id])
  @@index([account_id])
}

model Subscription {
  id         String             @id @default(uuid())
  user_id    String
  user       User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan       Plan
  status     SubscriptionStatus @default(ACTIVE)
  start_date DateTime
  end_date   DateTime?
  created_at DateTime           @default(now())

  @@index([user_id])
}

model Tag {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name       String
  is_ignored Boolean  @default(false)
  show_first Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([user_id, name])
}

model Emotion {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  value      String   // Stored value string (e.g. "CONFIDENT", "REVENGE")
  label      String   // Display label in Persian (e.g. "با اطمینان")
  emoji      String   @default("💭")
  created_at DateTime @default(now())

  @@unique([user_id, value])
}

model DiscountCode {
  id             String         @id @default(uuid())
  code           String         @unique
  discountPercent Int
  maxUses        Int
  usedCount      Int            @default(0)
  expireDate     DateTime
  isAccountBound Boolean        @default(false)
  created_at     DateTime       @default(now())
  userDiscounts  UserDiscount[]
}

model UserDiscount {
  id             String       @id @default(uuid())
  user_id        String
  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  discount_id    String
  discountCode   DiscountCode @relation(fields: [discount_id], references: [id], onDelete: Cascade)
  used_at        DateTime     @default(now())

  @@unique([user_id, discount_id])
}

model SystemSetting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt
}

model ManualReceipt {
  id              String        @id @default(uuid())
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan            Plan
  period          String
  amount          Int
  discountCode    String?
  receipt_image   String
  status          ReceiptStatus @default(PENDING)
  rejectionReason String?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@index([user_id])
}

// --- Enums ---

enum Role {
  USER
  ADMIN
}

enum ReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Direction {
  BUY
  SELL
}


enum Mood {
  HAPPY
  NEUTRAL
  STRESSED
  ANXIOUS
  FRUSTRATED
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum ImportSource {
  MANUAL
  MT4_CSV
  MT4_HTM
  MT5_CSV
  MT5_EA
  CRYPTO_API
}

enum ImportStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DisplayCurrency {
  USD
  TOMAN
  BOTH
}

model Otp {
  id         String   @id @default(uuid())
  phone      String
  code       String
  expires_at DateTime
  created_at DateTime @default(now())
  used       Boolean  @default(false)

  @@index([phone])
}

model CryptoTransaction {
  id           String            @id @default(uuid())
  user_id      String
  user         User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tx_hash      String            @unique
  coin         String
  amount       Float
  plan         Plan
  period       String
  status       CryptoTxStatus    @default(PENDING)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  @@index([user_id])
}

model ExchangeConnection {
  id            String    @id @default(uuid())
  account_id    String    @unique
  account       Account   @relation(fields: [account_id], references: [id], onDelete: Cascade)
  exchange_id   String    // e.g. "binance", "nobitex"
  api_key       String    // encrypted
  api_secret    String    // encrypted
  passphrase    String?   // encrypted (optional)
  last_trade_id String?   // last synced trade ID
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([account_id])
}


enum CryptoTxStatus {
  PENDING
  COMPLETED
  FAILED
}

model CheckoutSession {
  id            String   @id @default(uuid())
  gateway       String   // "zarinpal" or "payping"
  authority     String   @unique // ZarinPal authority string OR PayPing session code
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan          Plan
  period        String
  amount        Float
  discountCode  String?
  created_at    DateTime @default(now())

  @@index([user_id])
  @@index([authority])
}

// ─── Support Chat ──────────────────────────────────────────────────────────────

model Conversation {
  id               String             @id @default(uuid())
  user_id          String
  user             User               @relation("UserConversations", fields: [user_id], references: [id], onDelete: Cascade)
  subject          String
  status           ConversationStatus @default(OPEN)
  priority         Priority           @default(NORMAL)
  category         SupportCategory    @default(GENERAL)
  assigned_admin_id String?
  assigned_admin   User?              @relation("AdminConversations", fields: [assigned_admin_id], references: [id], onDelete: SetNull)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  resolved_at      DateTime?
  closed_at        DateTime?
  messages         Message[]
  activities       ConversationActivity[]

  @@index([user_id])
  @@index([status])
  @@index([assigned_admin_id])
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender_id       String
  sender          User         @relation("MessageSender", fields: [sender_id], references: [id], onDelete: Cascade)
  body            String
  attachments     String[]     @default([])
  read_at         DateTime?
  created_at      DateTime     @default(now())

  @@index([conversation_id, created_at])
}

model ConversationActivity {
  id              String       @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  actor_id        String
  actor           User         @relation("ActivityActor", fields: [actor_id], references: [id], onDelete: Cascade)
  action          String
  details         Json?
  created_at      DateTime     @default(now())

  @@index([conversation_id, created_at])
}

enum ConversationStatus {
  OPEN
  WAITING
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportCategory {
  GENERAL
  TECHNICAL
  BILLING
  FEATURE_REQUEST
  BUG_REPORT
}

// ─── System Logs ──────────────────────────────────────────────────────────────

enum LogLevel {
  INFO
  WARN
  ERROR
  FATAL
}

model SystemLog {
  id         String    @id @default(uuid())
  level      LogLevel
  source     String
  message    String
  details    Json?
  created_at DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([created_at])
}

