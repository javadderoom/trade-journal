// Prisma Schema for معامله‌یار (Mo'amele-yar) Trading Journal Platform

datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["fullTextSearchPostgres"]
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  phone            String           @unique
  password_hash    String
  name             String?
  plan             Plan             @default(FREE)
  role             Role             @default(USER)
  created_at       DateTime         @default(now())
  display_currency DisplayCurrency  @default(USD)
  avatar_url       String?
  deleted_at       DateTime?
  accounts         Account[]
  journalEntries   JournalEntry[]
  subscriptions    Subscription[]
  trades           Trade[]
  importJobs       ImportJob[]
  tags             Tag[]
  emotions         Emotion[]
  refresh_tokens   RefreshToken[]
  userDiscounts    UserDiscount[]
  manualReceipts   ManualReceipt[]
}

model Account {
  id             String         @id @default(uuid())
  user_id        String
  user           User           @relation(fields: [user_id], references: [id])
  broker_name    String?
  account_number String?
  currency       String         @default("USD")
  created_at     DateTime       @default(now())
  trades         Trade[]
  importJobs     ImportJob[]
  account_tokens AccountToken[]
  last_sync_at   DateTime?
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())
  user_agent String?
  last_used_at DateTime @default(now())

  @@index([user_id])
}

model AccountToken {
  id         String   @id @default(uuid())
  account_id String
  account    Account  @relation(fields: [account_id], references: [id], onDelete: Cascade)
  token      String   @unique
  name       String?
  created_at DateTime @default(now())

  @@index([account_id])
}

model Trade {
  id            String       @id @default(uuid())
  account_id    String
  user_id       String
  account       Account      @relation(fields: [account_id], references: [id])
  user          User         @relation(fields: [user_id], references: [id])
  symbol        String
  direction     Direction
  open_time     DateTime
  close_time    DateTime?
  open_price    Float
  close_price   Float?
  lot_size      Float
  stop_loss     Float?
  take_profit   Float?
  profit_usd    Float
  commission    Float
  swap          Float
  pips          Float
  r_multiple    Float
  tags          String[]
  emotion       String?
  notes         String?
  ticket        Int?         // MT4/MT5 deal ticket for deduplication
  import_source ImportSource @default(MANUAL)
  screenshots   String[]     @default([])
  chart_data    Json?
  created_at    DateTime     @default(now())

  @@unique([account_id, ticket])
  @@index([user_id])
  @@index([account_id])
}

model JournalEntry {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  date       DateTime
  body       String
  mood       Mood?
  created_at DateTime @default(now())
}

model ImportJob {
  id             String       @id @default(uuid())
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  account_id     String?
  account        Account?     @relation(fields: [account_id], references: [id])
  filename       String
  status         ImportStatus @default(UPLOADED)
  rows_total     Int
  rows_imported  Int          @default(0)
  errors         String[]
  created_at     DateTime     @default(now())
}

model Subscription {
  id         String             @id @default(uuid())
  user_id    String
  user       User               @relation(fields: [user_id], references: [id])
  plan       Plan
  status     SubscriptionStatus @default(ACTIVE)
  start_date DateTime
  end_date   DateTime?
  created_at DateTime           @default(now())
}

model Tag {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name       String
  is_ignored Boolean  @default(false)
  show_first Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([user_id, name])
}

model Emotion {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  value      String   // Stored value string (e.g. "CONFIDENT", "REVENGE")
  label      String   // Display label in Persian (e.g. "با اطمینان")
  emoji      String   @default("💭")
  created_at DateTime @default(now())

  @@unique([user_id, value])
}

model DiscountCode {
  id             String         @id @default(uuid())
  code           String         @unique
  discountPercent Int
  maxUses        Int
  usedCount      Int            @default(0)
  expireDate     DateTime
  isAccountBound Boolean        @default(false)
  created_at     DateTime       @default(now())
  userDiscounts  UserDiscount[]
}

model UserDiscount {
  id             String       @id @default(uuid())
  user_id        String
  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  discount_id    String
  discountCode   DiscountCode @relation(fields: [discount_id], references: [id], onDelete: Cascade)
  used_at        DateTime     @default(now())

  @@unique([user_id, discount_id])
}

model SystemSetting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt
}

model ManualReceipt {
  id              String        @id @default(uuid())
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan            Plan
  period          String
  amount          Int
  discountCode    String?
  receipt_image   String
  status          ReceiptStatus @default(PENDING)
  rejectionReason String?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@index([user_id])
}

// --- Enums ---

enum Role {
  USER
  ADMIN
}

enum ReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Direction {
  BUY
  SELL
}


enum Mood {
  HAPPY
  NEUTRAL
  STRESSED
  ANXIOUS
  FRUSTRATED
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum ImportSource {
  MANUAL
  MT4_CSV
  MT4_HTM
  MT5_CSV
  MT5_EA
}

enum ImportStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DisplayCurrency {
  USD
  TOMAN
  BOTH
}
