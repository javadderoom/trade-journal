# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/trade_journal?schema=public"

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD="your_redis_password_here"
REDIS_URL="redis://:${REDIS_PASSWORD}@localhost:6379"

# ─── Auth ───────────────────────────────────────────────────
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your_64_char_hex_secret_here"
JWT_ACCESS_EXPIRES_IN="15m"

# ─── Encryption ─────────────────────────────────────────────
# REQUIRED in production. 64-char hex string for AES-256-GCM.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_ENCRYPTION_KEY="your_64_char_hex_key_here"

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins. In dev, localhost is auto-allowed.
CORS_ORIGINS="http://localhost:3001"

# ─── SMS (Kavenegar) ───────────────────────────────────────
# Optional — falls back to mock logging if not set
KAVENEGAR_API_KEY=""
KAVENEGAR_OTP_TEMPLATE=""

# ─── Payment: PayPing ──────────────────────────────────────
PAYPING_TOKEN=""

# ─── Payment: ZarinPal ─────────────────────────────────────
ZARINPAL_MERCHANT_ID=""
ZARINPAL_SANDBOX="true"
MOCK_PAYMENT="true"

# ─── Email (Resend) ─────────────────────────────────────────
# REQUIRED for email verification. Get key at https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="TradeKav <noreply@tradekav.ir>"
FRONTEND_URL="http://localhost:3001"

# ─── Exchange Rate API (Navasan) ───────────────────────────
NAVASAN_API_KEY=""
